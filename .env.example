# ─────────────────────────────────────────────────────────────────
#  Daily Stock Briefing — Configuration
#  Copy this file to .env for local testing.
#  For production, add these as GitHub Actions Secrets instead.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Google Gemini ─────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model options:
# Model name — set this to whichever Gemini model you have quota for:
#   gemini-3.1-flash-lite  → fast, free tier (recommended)
#   gemini-3.1-flash       → higher quality
#   gemini-2.0-flash       → older fallback
GEMINI_MODEL=gemini-3.1-flash-lite

# ── Telegram ─────────────────────────────────────────────────────
# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Your girlfriend's Telegram chat ID (she must message the bot first,
# then call: https://api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_CHAT_ID=987654321
